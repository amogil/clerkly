{
  "name": "clerkly",
  "version": "1.0.0",
  "description": "Clerkly - AI Agent для менеджеров. Electron-приложение для Mac OS X с локальным хранением данных.",
  "main": "dist/main/main/index.js",
  "author": "Clerkly Team",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "start": "npm run rebuild:electron && npm run build && npm run package:mac && (pkill -f '/Clerkly.app/Contents/MacOS/Clerkly' || true) && sleep 1 && open release/mac-arm64/Clerkly.app --args --user-data-dir \"$PWD/release\"",
    "dev": "npm run build && electron .",
    "dev:app": "npm run build && npx electron-builder --mac --dir && open release/mac-arm64/Clerkly.app",
    "build": "npm run build:main && npm run build:renderer && npm run build:preload",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:preload": "tsc -p tsconfig.preload.json",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "npm run rebuild:node && npm run test:unit",
    "test:unit": "jest --config jest.unit.config.js",
    "test:functional": "npm run rebuild:electron && npm run build && playwright test",
    "test:functional:verbose": "npm run rebuild:electron && npm run build && playwright test --reporter=list",
    "test:functional:debug": "npm run rebuild:electron && npm run build && playwright test --reporter=list --max-failures=1",
    "test:functional:single": "npm run rebuild:electron && npm run build && playwright test --reporter=list",
    "test:coverage": "jest --config jest.combined.config.js --coverage --runInBand --openHandlesTimeout=5000",
    "test:coverage:separate": "jest --config jest.unit.config.js --coverage --coverageDirectory=coverage/unit",
    "test:watch": "jest --watch",
    "lint": "npx eslint . --ext .ts,.tsx",
    "lint:fix": "npx eslint . --ext .ts,.tsx --fix",
    "format": "npx prettier --write \"src/**/*.{ts,tsx,json}\" \"tests/**/*.{ts,tsx,json}\"",
    "format:check": "npx prettier --check \"src/**/*.{ts,tsx,json}\" \"tests/**/*.{ts,tsx,json}\"",
    "validate": "bash scripts/validate.sh",
    "validate:verbose": "bash scripts/validate.sh --verbose",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/react": "^3.0.118",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.116",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.38.4",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.487.0",
    "mitt": "^3.0.1",
    "motion": "^12.34.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.55.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.7",
    "react-responsive-masonry": "^2.7.1",
    "react-slick": "^0.31.0",
    "recharts": "^2.15.2",
    "sonner": "^2.0.3",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.3.8",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2",
    "yaml": "^2.8.2",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^0.30.6",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-util": "^30.2.0",
    "playwright": "^1.58.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.12",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.clerkly.app",
    "productName": "Clerkly",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "migrations/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "minimumSystemVersion": "10.13.0"
    },
    "protocols": [
      {
        "name": "Clerkly OAuth",
        "schemes": [
          "com.googleusercontent.apps.100365225505-9039l9g72mja9onmlkoupkphbns6lrg2"
        ]
      }
    ]
  }
}
