{
  "name": "clerkly2",
  "version": "1.0.0",
  "description": "Clerkly - AI Agent для менеджеров",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron dist/main.js",
    "dev": "tsc && electron dist/main.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:property": "jest tests/property",
    "test:functional": "jest tests/functional",
    "test:coverage": "jest --coverage",
    "validate": "bash scripts/validate.sh",
    "dist": "npm run build && electron-builder --mac --publish never",
    "tsc": "tsc --noEmit",
    "tsc:main": "tsc -p tsconfig.main.json --noEmit",
    "tsc:renderer": "tsc -p tsconfig.renderer.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.clerkly.app",
    "productName": "Clerkly",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "minimumSystemVersion": "10.13.0"
    },
    "files": [
      "dist/**/*",
      "index.html",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist-build"
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.0",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "fast-check": "^4.5.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
