{
  "name": "clerkly",
  "version": "1.0.0",
  "description": "Clerkly - AI Agent для менеджеров. Electron-приложение для Mac OS X с локальным хранением данных.",
  "main": "dist/main/index.js",
  "author": "Clerkly Team",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "npm run build:main && npm run build:renderer && npm run build:preload",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "test": "jest",
    "test:unit": "jest --testPathPattern='tests/unit'",
    "test:property": "jest --testPathPattern='tests/property'",
    "test:functional": "jest --testPathPattern='tests/functional'",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "npx eslint . --ext .ts,.tsx",
    "lint:fix": "npx eslint . --ext .ts,.tsx --fix",
    "format": "npx prettier --write \"src/**/*.{ts,tsx,json}\" \"tests/**/*.{ts,tsx,json}\"",
    "format:check": "npx prettier --check \"src/**/*.{ts,tsx,json}\" \"tests/**/*.{ts,tsx,json}\"",
    "validate": "bash scripts/validate.sh",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.9",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "fast-check": "^3.22.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-util": "^30.2.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.clerkly.app",
    "productName": "Clerkly",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/index.html",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "minimumSystemVersion": "10.13.0"
    }
  }
}
