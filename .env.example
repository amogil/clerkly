# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API key for LLM integration
# Required for llm-chat functional tests and real LLM usage
CLERKLY_OPENAI_API_KEY=your-key-here

# Google OAuth client secret for OAuth token exchange
# Used for build-time injection into the packaged main process
CLERKLY_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret-here
