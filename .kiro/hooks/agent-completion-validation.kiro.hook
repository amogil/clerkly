{
  "enabled": true,
  "name": "Agent Completion Validation",
  "description": "Runs npm run validate to check all changes when agent execution finishes",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Запусти `npm run validate` для валидации всех изменений. Если есть ошибки или замечания - исправь их согласно правилам из AGENTS.md\n"
  },
  "workspaceFolderName": "clerkly",
  "shortName": "agent-completion-validation"
}