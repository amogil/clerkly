{
  "enabled": true,
  "name": "Run `npm run validate` ",
  "description": "Runs `npm run validate`",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run `npm run validate`. Fix all problems. Do NOT run functional tests as they show windows and interrupt work."
  },
  "workspaceFolderName": "clerkly2",
  "shortName": "auto-validate-on-save"
}